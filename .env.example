# InjectGuard model keys — copy to ".env" and fill in. ".env" is git-ignored; never commit it.
#
# Cheap tiers only. Hard spend cap ~$100 for v1. v1 roster is 3 cheap models.

# Groq — runs Llama (free tier). https://console.groq.com/keys
GROQ_API_KEY=

# Google — Gemini Flash (cheap). https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# OpenRouter — USE ONLY "DeepSeek V4 Flash". NEVER route an expensive model
# (GPT-4 / Claude Opus / etc.) through OpenRouter. https://openrouter.ai/keys
OPENROUTER_API_KEY=
